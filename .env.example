# ============================================================
# CcharmyShah — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Razorpay ─────────────────────────────────────────────────
# Get this from: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# ── Razorpay Hosted Links ───────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── App URL (for OG tags and callbacks) ──────────────────────
NEXT_PUBLIC_APP_URL=https://yourapp.com



# --- Gmail SMTP (For enquiry + booking email notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=urmail@gmail.com
SMTP_PASS=abcdefghijklmnop
SMTP_FROM_NAME=Ccharmy Shah
SMTP_USER=urmail@gmail.com
ENQUIRY_BOOKING_NOTIFICATION_EMAIL=urmail@gmail.com
BOOKING_NOTIFICATION_EMAIL=urmail@gmail.com
